rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /bottles/{allPaths=**} {
      // Allow read access to all images (so the public can see shared links if needed, 
      // or at least the owner can see them in various contexts)
      allow read: if true;
      
      // Allow authenticated users to upload their own images
      // We check for auth != null to allow anonymous users
      allow write: if request.auth != null 
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
