rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBottle(data) {
      return data.keys().hasAll(['name', 'winery', 'userId', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.winery is string && data.winery.size() <= 200
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        // Optional fields
        && (!data.keys().contains('type') || (data.type in ['Red', 'White', 'Rosé', 'Sparkling', 'Dessert', 'Fortified']))
        && (!data.keys().contains('vintage') || (data.vintage is int && data.vintage >= 1800 && data.vintage <= 2100))
        && (!data.keys().contains('rating') || (data.rating is number && data.rating >= 1 && data.rating <= 5))
        && (!data.keys().contains('price') || (data.price is number && data.price >= 0))
        && (!data.keys().contains('region') || (data.region is string && data.region.size() <= 200))
        && (!data.keys().contains('country') || (data.country is string && data.country.size() <= 100))
        && (!data.keys().contains('quantity') || (data.quantity is number && data.quantity >= 0))
        && (!data.keys().contains('grapes') || (data.grapes is string && data.grapes.size() <= 500))
        && (!data.keys().contains('note') || (data.note is string && data.note.size() <= 5000))
        && (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 2000))
        && (!data.keys().contains('tastingNotes') || (data.tastingNotes is string && data.tastingNotes.size() <= 5000));
    }

    // --- Collections ---

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && (!data.keys().contains('description') || (data.description is string && data.description.size() <= 5000));
    }

    match /menuItems/{menuItemId} {
      allow get: if isOwner(existing().userId);
      allow list: if isOwner(resource.data.userId);

      allow create: if isSignedIn() 
        && isValidId(menuItemId)
        && isValidMenuItem(incoming())
        && incoming().createdAt == request.time;

      allow update: if isOwner(existing().userId)
        && isValidMenuItem(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'description'
          ])
        );

      allow delete: if isOwner(existing().userId);
    }

    match /bottles/{bottleId} {
      allow get: if isOwner(existing().userId);
      allow list: if isOwner(resource.data.userId);

      allow create: if isSignedIn() 
        && isValidId(bottleId)
        && isValidBottle(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isOwner(existing().userId)
        && isValidBottle(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && (
          // Action: General Update
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'winery', 'type', 'vintage', 'region', 'country', 'quantity', 'grapes', 'note', 'imageUrl',
            'rating', 'tastingNotes', 'price', 'purchaseDate', 'updatedAt'
          ])
        );

      allow delete: if isOwner(existing().userId);
    }
  }
}
